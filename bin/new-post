#!/bin/bash
set -euo pipefail

SCRIPT_DIR=$(dirname "$0")
FILENAME="input/posts/$(date -I)_todo.md"

cat << MARKDOWN > "$SCRIPT_DIR/../$FILENAME"
{:title "TODO"
 :main-image {:uri "/images/posts/XXXXXX.jpg"
              :artist {:name "Person McPerson"
                       :url "https://unsplash.com/photos/a-black-and-white-photo-of-a-large-ship-sSBZcdyCzxs"}}
 :tags [:bleet :management]}

Teaser content goes here, before the comment below.

<!--more-->

## Tags

- bleet
- cocoa
- coding-styleconventions
- coding-tips
- mentoring
- management
- modern-opengl
- random-stuff
- ruby
- software-design
- software-processes
- testing
- web

MARKDOWN

echo "$FILENAME"
